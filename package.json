<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Desk — Structured Recruiting Guidance</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,ital,wght@9..144,0,300;9..144,0,400;9..144,1,300;9..144,1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
:root{
  --cream:#F7F3EE;--warm:#FDFAF7;
  --ink:#1A1714;--ink60:rgba(26,23,20,0.6);--ink40:rgba(26,23,20,0.4);
  --ink15:rgba(26,23,20,0.15);--ink08:rgba(26,23,20,0.08);
  --terra:#B85C38;--terra-pale:#F5EDE8;
}
body{font-family:"DM Sans",sans-serif;background:var(--warm);color:var(--ink);overflow-x:hidden;}

nav{position:fixed;top:0;left:0;right:0;z-index:200;height:56px;display:flex;align-items:center;padding:0 20px;background:rgba(253,250,247,0.97);backdrop-filter:blur(12px);border-bottom:0.5px solid var(--ink08);}
.nav-logo{font-family:"Fraunces",serif;font-size:22px;font-weight:400;letter-spacing:-0.3px;color:var(--ink);flex:1;}
.nav-logo em{font-style:italic;color:var(--terra);}
.nav-beta{
  font-family:"DM Sans",sans-serif;
  font-size:9px;font-weight:600;
  letter-spacing:0.14em;text-transform:uppercase;
  color:var(--terra);
  background:var(--terra-pale);
  border:0.5px solid rgba(184,92,56,0.25);
  border-radius:100px;
  padding:3px 9px;
  margin-left:-8px;
  flex-shrink:0;
}
.nav-links,.nav-spacer,.nav-login,.nav-cta{display:none;}
.nav-hamburger{display:flex;flex-direction:column;gap:5px;cursor:pointer;padding:6px;}
.nav-hamburger span{display:block;width:22px;height:1.5px;background:var(--ink);border-radius:2px;transition:all 0.2s;}
.nav-hamburger.open span:nth-child(1){transform:translateY(6.5px) rotate(45deg);}
.nav-hamburger.open span:nth-child(2){opacity:0;}
.nav-hamburger.open span:nth-child(3){transform:translateY(-6.5px) rotate(-45deg);}

.mobile-menu{display:none;position:fixed;top:56px;left:0;right:0;background:rgba(253,250,247,0.98);backdrop-filter:blur(16px);border-bottom:0.5px solid var(--ink08);z-index:199;padding:8px 20px 20px;flex-direction:column;}
.mobile-menu.open{display:flex;}
.mobile-menu-link{font-size:16px;font-weight:400;color:var(--ink60);padding:14px 0;border-bottom:0.5px solid var(--ink08);cursor:pointer;}
.mobile-menu-link:last-of-type{border-bottom:none;}
.mobile-menu-actions{display:flex;gap:12px;margin-top:16px;}
.mm-login{flex:1;text-align:center;font-size:14px;color:var(--ink40);border:0.5px solid var(--ink15);padding:12px;border-radius:100px;}
.mm-cta{flex:1;text-align:center;font-size:14px;font-weight:500;color:white;background:var(--ink);padding:12px;border-radius:100px;}

.hero{margin-top:56px;display:flex;flex-direction:column;}
.hero-left{padding:20px 20px 16px;background:var(--warm);}
.hero-eyebrow{font-size:10px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:var(--terra);margin-bottom:10px;}
.hero-logo{font-family:"Fraunces",serif;font-size:52px;font-weight:300;letter-spacing:-2px;line-height:1;color:var(--ink);margin-bottom:10px;}
.hero-logo em{font-style:italic;color:var(--terra);}
.hero-strapline{font-family:"Fraunces",serif;font-size:19px;font-weight:300;letter-spacing:-0.3px;color:var(--ink);line-height:1.3;margin-bottom:6px;}
.hero-desc{font-size:13px;font-weight:300;line-height:1.65;color:var(--ink60);margin-bottom:12px;}
.hero-get-started{margin-top:6px;}
.hero-get-started-sub{font-size:13px;font-weight:300;color:var(--ink60);line-height:1.65;margin-bottom:12px;margin-top:0;max-width:480px;}
.hero-get-started-link{
  font-family:"Fraunces",serif;
  font-size:clamp(17px,2.5vw,24px);
  font-weight:300;letter-spacing:-0.5px;
  cursor:pointer;
  transition:all 0.2s;
  display:inline-flex;align-items:center;gap:10px;
  border:1.5px solid var(--ink);
  border-radius:100px;
  padding:8px 20px 8px 16px;
  margin-top:4px;
  background:transparent;
}
.hero-get-started-link:hover{
  background:var(--ink);
  border-color:var(--ink);
}
.hero-get-started-link:hover .gs-get{color:white;}
.hero-get-started-link:hover .gs-started{color:white;}
.gs-get{color:var(--ink);transition:color 0.2s;}
.gs-started{color:var(--terra);transition:color 0.2s;}
.gs-arrow{color:var(--terra);transition:color 0.2s;}
.provenance-strip{margin-top:28px;padding-top:20px;border-top:0.5px solid var(--ink08);}
.provenance-label{font-size:9px;font-weight:600;letter-spacing:0.16em;text-transform:uppercase;color:var(--ink40);margin-bottom:14px;}
.provenance-logos{display:flex;flex-wrap:nowrap;gap:24px;align-items:center;overflow-x:auto;scrollbar-width:none;padding-bottom:2px;}
.provenance-logos::-webkit-scrollbar{display:none;}
.provenance-logo-img{height:24px;width:auto;max-width:100px;object-fit:contain;filter:grayscale(100%);opacity:0.35;transition:opacity 0.2s;}
.provenance-logo-img:hover{opacity:0.6;}
.hero-get-started-link:hover .gs-arrow{color:white;}
.gs-free{font-family:"DM Sans",sans-serif;font-size:11px;font-weight:400;color:var(--ink40);letter-spacing:0.02em;transition:color 0.2s;white-space:nowrap;}
.hero-get-started-link:hover .gs-free{color:rgba(255,255,255,0.55);}

.hero-right{display:flex;flex-direction:column;gap:8px;padding:12px 14px 16px;background:var(--cream);min-height:0;}

.hr-welcome{background:var(--warm);border:0.5px solid var(--ink08);border-radius:13px;padding:12px 14px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.hr-greeting{font-size:9px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--ink40);margin-bottom:3px;}
.hr-name{font-family:"Fraunces",serif;font-size:17px;font-weight:400;letter-spacing:-0.3px;color:var(--ink);margin-bottom:2px;}
.hr-detail{font-size:11px;font-weight:300;color:var(--ink40);}

.hr-markets{background:var(--warm);border:0.5px solid var(--ink08);border-radius:13px;padding:13px 14px 10px;flex-shrink:0;}
.hr-img-wrap{flex-shrink:0;border-radius:6px;overflow:hidden;height:200px;}
.hr-markets-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px 0;margin-bottom:10px;}
.hr-ms{padding-right:10px;}
.hr-ms:nth-child(even){border-left:0.5px solid var(--ink08);padding-left:10px;padding-right:0;}
.hr-ms-label{font-size:9px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink40);margin-bottom:2px;}
.hr-ms-val{font-family:"Fraunces",serif;font-size:14px;font-weight:400;color:var(--ink);letter-spacing:-0.2px;line-height:1;}
.hr-ms-chg{font-size:10px;font-weight:500;margin-top:1px;}
.up{color:#1A6B3A;}.dn{color:#B85C38;}
.hr-chart{width:100%;height:40px;display:block;}
.hr-markets-label{font-size:9px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--ink40);margin-top:6px;}

.hr-brief{background:var(--terra-pale);border:0.5px solid rgba(184,92,56,0.18);border-radius:12px;padding:12px 14px;display:flex;align-items:flex-start;justify-content:space-between;gap:8px;cursor:pointer;transition:background 0.15s;flex-shrink:0;}
.hr-brief:hover{background:rgba(184,92,56,0.1);}
.hr-brief-tag{font-size:9px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--terra);margin-bottom:5px;}
.hr-brief-title{font-family:"Fraunces",serif;font-size:13px;font-weight:400;color:var(--ink);line-height:1.5;}
.hr-brief-arrow{font-size:16px;color:var(--terra);flex-shrink:0;margin-top:2px;}

.hr-story{background:var(--warm);border:0.5px solid var(--ink08);border-radius:11px;padding:10px 13px;cursor:pointer;transition:background 0.15s,border-color 0.15s;flex-shrink:0;}
.hr-story:hover{background:var(--cream);border-color:var(--ink15);}
.hr-story-meta{display:flex;align-items:center;gap:5px;font-size:9px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--terra);margin-bottom:4px;}
.hr-dot{width:4px;height:4px;border-radius:50%;background:var(--terra);flex-shrink:0;}
.hr-story-hl{font-family:"Fraunces",serif;font-size:13px;font-weight:400;color:var(--ink);line-height:1.4;}

.section{padding:36px 20px;border-bottom:0.5px solid var(--ink08);}
.section-eyebrow{font-size:10px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:var(--ink40);margin-bottom:6px;}
.section-h2{font-family:"Fraunces",serif;font-size:26px;font-weight:300;letter-spacing:-1px;line-height:1.1;color:var(--ink);}
.section-h2 em{font-style:italic;color:var(--terra);}
.section-header{display:flex;align-items:baseline;gap:10px;margin-bottom:20px;cursor:pointer;}
.section-arrow{font-size:12px;color:var(--terra);opacity:0;transition:opacity 0.15s;}
.section-header:hover .section-arrow{opacity:1;}

.logo-slider-wrap{margin:0 -20px;padding:0 20px;}
.logo-track{display:flex;gap:28px;overflow-x:auto;scroll-behavior:smooth;scrollbar-width:none;padding:6px 0;align-items:center;}
.logo-track::-webkit-scrollbar{display:none;}
.logo-tile{flex-shrink:0;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:opacity 0.2s,transform 0.2s;background:none;border:none;padding:0;}
.logo-track:hover .logo-tile{opacity:0.3;}
.logo-track:hover .logo-tile:hover{opacity:1;transform:scale(1.07);}
.logo-tile img{height:80px;width:auto;max-width:240px;object-fit:contain;display:block;filter:grayscale(15%);transition:filter 0.2s;}
.logo-tile:hover img{filter:grayscale(0%);}

.app-guides-header{padding:56px 20px 0;}
.app-guides-header .agh-eyebrow{font-size:10px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:var(--ink40);margin-bottom:6px;}
.app-guides-header h2{font-family:"Fraunces",serif;font-size:clamp(22px,3vw,34px);font-weight:300;letter-spacing:-0.8px;line-height:1.15;color:var(--ink);margin-top:0;}
.app-guides-header h2 em{font-style:italic;color:var(--terra);}
.app-guides-header p{font-size:13px;font-weight:300;color:var(--ink60);line-height:1.7;margin-top:7px;}


.mot-card-title{font-family:"Fraunces",serif;font-size:15px;font-weight:400;color:var(--ink);line-height:1.3;}
.mot-body{padding:16px;}
.mot-field{margin-bottom:10px;}
.mot-label{font-size:9px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink40);margin-bottom:3px;}
.mot-val{font-size:13px;color:var(--ink);background:var(--cream);border:0.5px solid var(--ink15);border-radius:8px;padding:9px 11px;width:100%;}
.cv-upload{border:1px dashed var(--ink15);border-radius:10px;padding:13px;text-align:center;cursor:pointer;transition:all 0.15s;margin-bottom:10px;}
.cv-upload:hover{border-color:var(--terra);background:var(--terra-pale);}
.cv-upload-icon{font-size:18px;margin-bottom:3px;}
.cv-upload-text{font-size:13px;color:var(--ink60);}
.cv-upload-sub{font-size:11px;color:var(--ink40);margin-top:1px;}
.cv-upload-btn{display:inline-block;margin-top:7px;font-size:11px;font-weight:500;color:var(--terra);border:0.5px solid var(--terra);border-radius:100px;padding:3px 11px;}
.mot-submit{display:block;width:100%;text-align:center;font-size:14px;font-weight:500;color:white;background:var(--ink);padding:12px;border-radius:10px;cursor:pointer;}
.mot-note{font-size:11px;color:var(--ink40);text-align:center;margin-top:6px;}

.fc-section{padding:36px 0 36px 20px;border-bottom:0.5px solid var(--ink08);}
.fc-section-header{margin-bottom:18px;padding-right:20px;}
.fc-track{display:flex;gap:13px;overflow-x:auto;scrollbar-width:none;padding-right:20px;padding-bottom:4px;}
.fc-track::-webkit-scrollbar{display:none;}
.fc{flex-shrink:0;width:230px;border-radius:16px;overflow:hidden;border:0.5px solid var(--ink08);background:var(--warm);cursor:pointer;transition:transform 0.2s,box-shadow 0.2s;}
.fc:hover{transform:translateY(-3px);box-shadow:0 10px 28px rgba(26,23,20,0.09);}
.fc-img{height:150px;width:100%;}
.fc-img svg{width:100%;height:100%;}
.fc-body{padding:12px 14px 16px;}
.fc-tag{font-size:9px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--terra);margin-bottom:5px;}
.fc-name{font-family:"Fraunces",serif;font-size:15px;font-weight:400;color:var(--ink);margin-bottom:4px;line-height:1.2;}
.fc-desc{font-size:11px;font-weight:300;color:var(--ink60);line-height:1.6;margin-bottom:8px;}
.fc-cta{font-size:11px;font-weight:500;color:var(--terra);}

.why{background:var(--ink);padding:44px 20px 0;}
.why-h2{font-family:"Fraunces",serif;font-size:26px;font-weight:300;letter-spacing:-1px;line-height:1.15;color:#F7F3EE;margin-bottom:12px;}
.why-h2 em{font-style:italic;color:var(--terra);}
.why-intro{font-size:13px;font-weight:300;color:rgba(247,243,238,0.45);line-height:1.7;margin-bottom:28px;padding-bottom:28px;border-bottom:0.5px solid rgba(247,243,238,0.08);}
.why-intro strong{color:rgba(247,243,238,0.75);font-weight:500;}
.why-grid{display:flex;flex-direction:column;}
.why-card{padding:22px 0;border-bottom:0.5px solid rgba(247,243,238,0.08);}
.why-card:last-child{border-bottom:none;}
.why-stat{font-family:"Fraunces",serif;font-size:40px;font-weight:300;letter-spacing:-2px;color:#F7F3EE;line-height:1;margin-bottom:7px;}
.why-stat em{font-style:italic;color:var(--terra);}
.why-card-title{font-size:13px;font-weight:500;color:rgba(247,243,238,0.7);margin-bottom:5px;}
.why-card-desc{font-size:12px;font-weight:300;color:rgba(247,243,238,0.35);line-height:1.65;}
.why-value{padding:32px 0;display:flex;flex-direction:column;gap:0;align-items:center;}
.why-testimonial{
  font-family:"Fraunces",serif;
  font-size:clamp(18px,2.2vw,26px);
  font-weight:300;
  font-style:italic;
  color:rgba(247,243,238,0.75);
  line-height:1.5;
  text-align:center;
  max-width:640px;
  margin:0 auto;
}
.why-testimonial-attr{
  display:block;
  font-family:"DM Sans",sans-serif;
  font-style:normal;
  font-size:12px;
  font-weight:500;
  color:var(--terra);
  margin-top:10px;
  letter-spacing:0.06em;
  text-transform:uppercase;
  text-align:center;
}
.why-value-text{font-family:"Fraunces",serif;font-size:17px;font-weight:300;font-style:italic;color:rgba(247,243,238,0.5);line-height:1.45;}
.why-value-text strong{font-style:normal;font-weight:400;color:#F7F3EE;}
.why-value-n{font-family:"Fraunces",serif;font-size:40px;font-weight:300;letter-spacing:-2px;color:#F7F3EE;line-height:1;}
.why-value-n em{font-style:italic;color:var(--terra);}
.why-value-sub{font-size:11px;font-weight:300;color:rgba(247,243,238,0.3);margin-top:2px;}

.pricing{background:var(--ink);padding:0 20px;border-top:0.5px solid rgba(247,243,238,0.08);}
.pricing-h2{font-family:"Fraunces",serif;font-size:26px;font-weight:300;letter-spacing:-1px;line-height:1.1;color:#F7F3EE;margin-bottom:5px;padding-top:36px;}
.pricing-h2 em{font-style:italic;color:var(--terra);}
.pricing-note{font-size:12px;font-weight:300;color:rgba(247,243,238,0.3);margin-bottom:24px;}
.tier{padding:22px 0;border-bottom:0.5px solid rgba(247,243,238,0.08);}
.tier:last-child{border-bottom:none;padding-bottom:36px;}
.tier-tag{font-size:9px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:rgba(247,243,238,0.28);margin-bottom:10px;}
.tier-emotional{
  font-size:11px;font-weight:400;font-style:italic;
  color:rgba(247,243,238,0.5);
  margin-bottom:8px;line-height:1.4;
}
.tier-price{font-family:"Fraunces",serif;font-size:32px;font-weight:300;letter-spacing:-1.5px;color:#F7F3EE;line-height:1;margin-bottom:3px;}
.tier-price em{font-style:italic;}
.tier-period{font-size:10px;font-weight:300;color:rgba(247,243,238,0.28);margin-bottom:10px;}
.tier-desc{font-size:12px;font-weight:300;color:rgba(247,243,238,0.45);line-height:1.65;margin-bottom:12px;}
.tier-cta{font-size:12px;font-weight:500;color:var(--terra);cursor:pointer;}

.cta{background:var(--ink);padding:0 20px 44px;text-align:center;}
.cta-h2{font-family:"Fraunces",serif;font-size:30px;font-weight:300;letter-spacing:-1.2px;line-height:1.1;color:#F7F3EE;margin-bottom:12px;padding-top:28px;border-top:0.5px solid rgba(247,243,238,0.08);}
.cta-h2 em{font-style:italic;color:var(--terra);}
.cta-sub{font-size:13px;font-weight:300;color:rgba(247,243,238,0.35);margin-bottom:22px;line-height:1.6;}
.btn-cream{display:inline-block;font-size:14px;font-weight:500;color:var(--ink);background:#F7F3EE;padding:12px 26px;border-radius:100px;cursor:pointer;}

footer{padding:24px 20px;display:flex;flex-direction:column;gap:12px;border-top:0.5px solid var(--ink08);}
.footer-logo{font-family:"Fraunces",serif;font-size:17px;font-weight:400;color:var(--ink40);}
.footer-logo em{font-style:italic;color:var(--terra);}
.footer-links{display:flex;gap:18px;}
.footer-link{font-size:12px;font-weight:300;color:var(--ink40);}
.footer-note{font-size:11px;font-weight:300;color:var(--ink40);}

.reveal{opacity:0;transform:translateY(18px);transition:opacity 0.6s ease,transform 0.6s ease;}
.reveal.on{opacity:1;transform:translateY(0);}

@media(min-width:769px){
  nav{height:72px;padding:0 48px;}
  .nav-logo{font-size:28px;margin-right:52px;}
  .nav-links{display:flex;align-items:center;flex:1;}
  .nav-link{font-size:13px;font-weight:400;color:var(--ink40);padding:0 16px;height:72px;display:flex;align-items:center;cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;}
  .nav-link:hover{color:var(--ink);border-bottom-color:var(--terra);}
  .nav-spacer{flex:1;}
  .nav-login{display:block;font-size:13px;font-weight:400;color:var(--ink40);cursor:pointer;margin-right:20px;}
  .nav-cta{display:block;font-size:13px;font-weight:500;color:white;background:var(--ink);padding:10px 22px;border-radius:100px;cursor:pointer;}
  .nav-hamburger{display:none;}

  .hero{margin-top:72px;display:grid;grid-template-columns:1fr 1fr;height:auto;min-height:unset;max-height:unset;flex-direction:unset;}
  .hero-left{padding:28px 32px 28px 48px;display:flex;flex-direction:column;justify-content:center;}
  .hero-logo{font-size:clamp(46px,5vw,72px);letter-spacing:-3px;}
  .hero-strapline{font-size:clamp(16px,1.8vw,21px);}
  .hero-desc{font-size:13px;max-width:480px;}
  .hero-get-started-sub{max-width:480px;}
  .hero-right{padding:14px 14px 14px 10px;}
  .hr-name{font-size:18px;}
  .hr-markets-grid{grid-template-columns:repeat(4,1fr);}
  .hr-ms:nth-child(even){border-left:0.5px solid var(--ink08);}
  .hr-ms:nth-child(3){border-left:0.5px solid var(--ink08);}
  .logo-tile img{height:110px;max-width:300px;}
  .section{padding:56px 48px;}
  .section-h2{font-size:clamp(24px,2.8vw,38px);}
  .app-guides-header{padding:72px 48px 0;}
  .app-guides-header h2{font-size:clamp(24px,2.8vw,36px);}
  .app-guides-section{padding-left:48px;padding-right:48px;border-top:none;}
  .mot-section{padding:56px 48px;display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:start;}
  .mot-title{font-size:clamp(22px,2.6vw,34px);}
  .fc-section{padding:56px 0 56px 48px;}
  .fc{width:295px;}
  .fc-img{height:180px;}
  .why{padding:56px 72px 0;}
  .why-h2{font-size:clamp(24px,2.8vw,38px);}
  .why-grid{display:grid;grid-template-columns:repeat(3,1fr);}
  .why-card{border-right:0.5px solid rgba(247,243,238,0.08);border-bottom:0.5px solid rgba(247,243,238,0.08);padding:30px 22px;}
  .why-card:nth-child(3n){border-right:none;}
  .why-card:nth-last-child(-n+3){border-bottom:none;}
  .why-value{flex-direction:column;align-items:center;justify-content:center;padding:44px 0;}
  .why-testimonial{
