<script>
var revEls = document.querySelectorAll('.reveal');
var revObs = new IntersectionObserver(function(entries) {
  entries.forEach(function(e) {
    if(e.isIntersecting) { e.target.classList.add('on'); revObs.unobserve(e.target); }
  });
}, {threshold:0.06});
revEls.forEach(function(el) { revObs.observe(el); });

function toggleMenu() {
  var menu = document.getElementById('mobileMenu');
  var burger = document.getElementById('hamburger');
  if(menu) menu.classList.toggle('open');
  if(burger) burger.classList.toggle('open');
}

var cvUp = document.getElementById('cvUpload');
if(cvUp) cvUp.addEventListener('click', function() {
  this.innerHTML = '<div class="cv-upload-icon">✅</div><div class="cv-upload-text">CV_Robertson.pdf</div><div class="cv-upload-sub">Ready to analyse ✓</div>';
});


</script>
